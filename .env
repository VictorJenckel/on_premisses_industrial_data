# =============================================================================
#  .env.example — environment variables required by docker-compose.yaml
#
# =============================================================================

# --- Airflow security ---
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# --- Airflow admin user ---
AIRFLOW_ADMIN_EMAIL=admin@your-domain.local
AIRFLOW_ADMIN_PASSWORD=

# --- Airflow metadata database (postgres_dc2 container) ---
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=
AIRFLOW_DB_NAME=airflow_db

# --- Production inspection database (PostgreSQL on host, port 5432) ---
PG_DBNAME=dbc
PG_USER=
PG_PASSWORD=

# --- CUT2 inspection line machine (SSH/rsync access) ---
CUT2_MACHINE_IP=
CUT2_MACHINE_USER=
CUT2_MACHINE_PASS=
CUT2_REMOTE_DATA_DIR=/home/operator/CUT2_data/history

# --- Eagle Vision machines — Mirror1 and Cut1 lines (SMB access) ---
EAGLE_SMB_HOST=
EAGLE_SMB_USER=
EAGLE_SMB_PASS=
